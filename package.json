{
  "name": "ecommerce_backend",
  "version": "1.0.0",
  "main": "server.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "nodemon server.ts",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run",
    "seed:make": "knex seed:make",
    "migrate:make": "knex migrate:make -x ts",
    "migrate:rollback": "knex migrate:rollback",
    "autostart": "pm2 start dist/server.js  --name ecommerce-backend --max-restarts 5 --restart-delay 3000",
    "stop": "pm2 stop dist/server.js",
    "monitor": "pm2 monitor dist/server.js",
    "delete_ecommerce_pm2": "pm2 delete ecommerce-backend",
    "nginx:start": "brew services start nginx",
    "nginx:stop": "brew services stop nginx",
    "nginx:restart": "brew services restart nginx",
    "nginx:status": "brew services list | grep nginx"
  },
  "keywords": [
    "ECommerce",
    "PostgreSQL",
    "Docker",
    "Express",
    "PM2",
    "Knex.js"
  ],
  "author": "Kelechi Orunta",
  "license": "ISC",
  "description": "Backend server for the ECommerce product website built with PostgreSQL in docker cli runtime",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.9.3",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@cloudinary/url-gen": "^1.22.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.3.0",
    "cloudinary": "^2.10.0",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "knex": "^3.2.10",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "pm2": "^7.0.1",
    "redis": "^6.0.0",
    "ts-node": "^10.9.2"
  }
}
