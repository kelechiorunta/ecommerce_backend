    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@cloudinary/url-gen": "^1.22.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.3.0",
    "cloudinary": "^2.10.0",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
